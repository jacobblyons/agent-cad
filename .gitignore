# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
frontend/dist/
.vite/
*.log
*.tsbuildinfo

# Build artifacts
dist/
build/
*.spec

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local secrets
.env
.env.local
*.local

# pywebview cache
.pywebview/

# Generated CAD artifacts not under user control
*.gltf.cache

# Bambu Studio CLI dumps a result.json into its cwd on every invocation —
# we don't need it tracked.
/result.json
/frontend/result.json

# Claude Code local project state — but keep shared skills + agents tracked
# so contributors using Claude Code pick up the same tooling.
.claude/*
!.claude/skills/
!.claude/agents/
